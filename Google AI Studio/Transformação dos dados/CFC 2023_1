rio\"\n    ],\n    \"enunciado\": \"Em atenção ao Estatuto Nacional da Microempresa e da Empresa de Pequeno Porte, não poderá se beneficiar do tratamento jurídico diferenciado previsto em referido Estatuto, EXCETO:\",\n    \"opcoes\": [\n      {\n        \"letra\": \"A\",\n        \"texto\": \"Cooperativas de Crédito.\"\n      },\n      {\n        \"letra\": \"B\",\n        \"texto\": \"Pessoa jurídica que participe do capital de outra pessoa jurídica.\"\n      },\n      {\n        \"letra\": \"C\",\n        \"texto\": \"Empresa de pequeno porte que tenha participação de outra pessoa jurídica em seu capital.\"\n      },\n      {\n        \"letra\": \"D\",\n        \"texto\": \"No caso de microempresa, sociedade empresária devidamente registrada no Registro de Empresas Mercantis ou no Registro Civil de Pessoas Jurídicas, desde que aufira, em cada ano-calendário, receita bruta igual ou inferior a R$ 360.000,00.\"\n      }\n    ],\n    \"gabarito\": \"\",\n    \"gabarito_texto\": \"\",\n    \"resolucao\": \"\",\n    \"autor_resolucao\": \"\",\n    \"obsoleta\": false,\n    \"anulada\": false,\n    \"lancamentos\": []\n  }",
