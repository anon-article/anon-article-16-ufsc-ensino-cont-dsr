      }, {
        "text": "texto\": \"Surgimento de um passivo, sem o correspondente ativo.\"\n      },\n      {\n        \"letra\": \"D\",\n        \"texto\": \"Quando deixar de existir o correspondente valor ativo,"
      }, {
        "text": " por transferência de sua propriedade para terceiro.\"\n      }\n    ],\n    \"gabarito\": \"\",\n    "
      }, {
