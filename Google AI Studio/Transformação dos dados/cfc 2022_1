  \"letra\": \"A\",\n        \"texto\": \"A primeira proposta.\"\n      },\n      {\n        \"letra\": \"B\",\n        \"texto\": \"A segunda proposta.\"\n      },\n      {\n        \"letra\": \"C\",\n        \"texto\": \"A terceira proposta.\"\n      },\n      {\n        \"letra\": \"D\",\n        \"texto\": \"Nenhuma, pois todas as propostas apresentam o mesmo resultado.\"\n      }\n    ],\n    \"gabarito\": \"\",\n    \"gabarito_texto\": \"\",\n    \"resolucao\": \"\",\n    \"autor_resolucao\": \"\",\n    \"obsoleta\": false,\n    \"anulada\": false,\n    \"lancamentos\": []\n  },\n}",
