lucao\": \"\",\n    \"obsoleta\": false,\n    \"anulada\": false,\n    \"lancamentos\": []\n  },\n  {\n    \"id\": 4,\n    \"ano\": 2024,\n    \"exame\": \"CFC 2024/2\",\n    \"banca\": \"FGV\",\n    \"disciplina\": \"Matemática Financeira e Estatística\",\n    \"tags\": [\n      \"Fundamentos de Estatística\"\n    ],\n    \"enunciado\": [\n      {\n        \"type\": \"p\",\n        \"content\": \"Em relação a conceitos básicos de estatística, avalie se as afirmativas a seguir são falsas (F) ou verdadeiras (V).\"\n      },\n      {\n        \"type\": \"p\",\n        \"content\": \"I. A moda é uma medida de tendência central que apresenta a possibilidade de ser aplicada às variáveis qualitativas.\"\n      },\n      {\n        \"type\": \"p\",\n        \"content\": \"II. São exemplos de medida de dispersão a variância e o desvio-padrão, sendo a variância obtida pela raiz quadrada do desvio-padrão.\"\n      },\n      {\n        \"type\": \"p\",\n        \"content\": \"III. A média apresenta, em relação à mediana, a vantagem de não sofrer influência de valores extremos (outliers).\"\n      },\n      {\n        \"type\": \"p\",\n        \"content\": \"IV. Se uma variável é representada por números, ela será, necessariamente, uma variável quantitativa.\"\n      },\n      {\n        \"type\": \"p\",\n        \"content\": \"As afirmativas são, respectivamente,\"\n      }\n    ],\n    \"opcoes\": [\n      {\n        \"letra\": \"A\",\n        \"texto\": \"F – F – V – V.\"\n      },\n      {\n        \"letra\": \"B\",\n        \"texto\": \"F – V – F – V.\"\n      },\n      {\n        \"letra\": \"C\",\n        \"texto\": \"V – F – V – F.\"\n      },\n      {\n        \"letra\": \"D\",\n        \"texto\": \"V – F – F – F.\"\n      }\n    ],\n    \"gabarito\": \"\",\n    \"gabarito_texto\": \"\",\n    \"resolucao\": \"\",\n    \"autor_resolucao\": \"\",\n    \"obsoleta\": false,\n    \"anulada\": false,\n    \"lancamentos\": []\n  },\n  {\n    \"id\": 5,\n    \"ano\": 2024,\n    \"exame\": \"CFC 2024/2\",\n    \"banca\": \"FGV\",\n    \"disciplina\": \"Noções de Direito e Legislação Aplicada\",\n    \"tags\": [\n      \"Noções De Direito Público e Privado\"\n    ],\n    \"enunciado\": \"João recebeu comunicação da associação de moradores do Bairro Alfa informando que ele se encontrava em débito com as respectivas mensalidades desde a criação da associação, o que ocorrera dois anos antes. Ao comparecer perante a associação, João informou que jamais se associara, logo, não poderia ter débitos pendentes. Foi-lhe informado, no entanto, que isto era irrelevante, já que todas as conquistas da associação geravam benefícios para João, que era morador do Bairro Alfa.\u003cbr\u003eÀ luz dessa narrativa, é correto afirmar que\",\n    \"opcoes\": [\n      {\n        \"letra\": \"A\",\n        \"texto\": \"como é obrigatória a associação de João, o débito é devido, embora ele possa se desassociar a qualquer momento.\"\n      },\n      {\n        \"letra\": \"B\",\n        \"texto\": \"ainda que seja beneficiado pelos atos da associação, cabe a João decidir se irá se associar, ou não, logo, o débito é indevido.\"\n      },\n      {\n        \"letra\": \"C\",\n        \"texto\": \"caso a associação tenha sido criada com a autorização do Município, a associação de João é tida como obrigatória e o débito é devido.\"\n      },\n      {\n        \"letra\": \"D\",\n        \"texto\": \"como as associações não têm fins lucrativos, é vedada a cobrança de mensalidades, logo, o débito é indevido.\"\n      }\n    ],\n    \"gabarito\": \"\",\n    \"gabarito_texto\": \"\",\n    \"resolucao\": \"\",\n    \"autor_resolucao\": \"\",\n    \"obsoleta\": false,\n    \"anulada\": false,\n    \"lancamentos\": []\n  },\n  {\n    \"id\": 6,\n    \"ano\": 2024,\n    \"exame\": \"CFC 2024/2\",\n    \"banca\": \"FGV\",\n    \"disciplina\": \"Noções de Direito e Legislação Aplicada\",\n    \"tags\": [\n      \"Noções De Direito Público e Privado\"\n    ],\n    \"enunciado\": \"A sociedade empresária Alfa almejava celebrar um contrato com o Estado Beta, de modo que pudesse fornecer alguns móveis de sua fabricação. O objetivo decorria do fato de o Estado Beta estar finalizando a construção de dezenas de escolas públicas, tendo a necessidade de mobiliá-las no momento oportuno.\u003cbr\u003eAo consultar um especialista na matéria, foi corretamente informado ao sócio-gerente de Alfa que\",\n    \"opcoes\": [\n      {\n        \"letra\": \"A\",\n        \"texto\": \"os contratos celebrados pelo Estado sempre seguem os mesmos parâmetros dos contratos de direito privado, logo, Maria celebraria um contrato de compra e venda de bens móveis.\"\n      },\n      {\n        \"letra\": \"B\",\n        \"texto\": \"todo contrato celebrado pelo Estado Beta deve ser antecedido de licitação, logo, a sociedade empresária Alfa somente poderia fornecer móveis a esse ente federativo caso se saísse vencedora em licitação.\"\n      },\n      {\n        \"letra\": \"C\",\n        \"texto\": \"ressalvadas as exceções legais, eventual celebração de contrato administrativo com o Estado Beta exigiria que sociedade empresária Alfa fosse vencedora em licitação.\"\n      },\n      {\n        \"letra\": \"D\",\n        \"texto\": \"em razão do princípio da eficiência, que exige celeridade nas ações estatais, a realização de licitação é reservada às situações em que a autoridade administrativa identifique a possibilidade de competição.\"\n      }\n    ],\n    \"gabarito\": \"\",\n    \"gabarito_texto\": \"\",\n    \"resolucao\": \"\",\n    \"autor_resolucao\": \"\",\n    \"obsoleta\": false,\n    \"anulada\": false,\n    \"lancamentos\": []\n  },\n  {\n    \"id\": 7,\n    \"ano\": 2024,\n    \"exame\": \"CFC 2024/2\",\n    \"banca\": \"FGV\",\n    \"disciplina\": \"Noções de Direito e Legislação Aplicada\",\n    \"tags\": [\n      \"Direito Trabalhista e Legislação Social\"\n    ],\n    \"enunciado\": \"Ana trabalhava em um grande escritório de contabilidade, tendo sido questionada por Maria, sua colega, em relação aos pontos de aproximação e distanciamento entre os referenciais de previdência e assistência social, em especial na perspectiva do caráter contributivo, ou não.\u003cbr\u003eÀ luz desse questionamento, Ana respondeu corretamente que\",\n    \"opcoes\": [\n      {\n        \"letra\": \"A\",\n        \"texto\": \"ambas oferecem direitos prestacionais e têm caráter necessariamente contributivo.\"\n      },\n      {\n        \"letra\": \"B\",\n        \"texto\": \"a assistência social assegura benefícios independente de qualquer contribuição.\"\n      },\n      {\n        \"letra\": \"C\",\n        \"texto\": \"a assistência social se aproxima das características da previdência pública, mas se diferencia da previdência privada.\"\n      },\n      {\n        \"letra\": \"D\",\n        \"texto\": \"a assistência social é uma das formas de expressão da previdência social, seguindo as regras gerais desta última.\"\n      }\n    ],\n    \"gabarito\": \"\",\n    \"gabarito_texto\": \"\",\n    \"resolucao\": \"\",\n    \"autor_resolucao\": \"\",\n    \"obsoleta\": false,\n    \"anulada\": false,\n    \"lancamentos\": []\n  },\n  {\n    \"id\": 8,\n    \"ano\": 2024,\n    \"exame\": \"CFC 2024/2\",\n    \"banca\": \"FGV\",\n    \"disciplina\": \"Legislação e Ética Profissional\",\n    \"tags\": [\n      \"NBC PG 01\"\n    ],\n    \"enunciado\": \"De acordo com o CÓDIGO DE ÉTICA PROFISSIONAL DO CONTADOR em seu item 6 (letra b), o contador pode transferir o contrato de serviços a seu cargo a outro profissional, com a anuência, sempre por escrito, do\",\n    \"opcoes\": [\n      {\n        \"letra\": \"A\",\n        \"texto\": \"cliente.\"\n      },\n      {\n        \"letra\": \"B\",\n        \"texto\": \"seu superior.\"\n      },\n      {\n        \"letra\": \"C\",\n        \"texto\": \"executivo central da entidade em que trabalha.\"\n      },\n      {\n        \"letra\": \"D\",\n        \"texto\": \"acionista majoritário.\"\n      }\n    ],\n    \"gabarito\": \"\",\n    \"gabarito_texto\": \"\",\n    \"resolucao\": \"\",\n    \"autor_resolucao\": \"\",\n    \"obsoleta\": false,\n    \"anulada\": false,\n    \"lancamentos\": []\n  },\n  {\n    \"id\": 9,\n    \"ano\": 2024,\n    \"exame\": \"CFC 2024/2\",\n    \"banca\": \"FGV\",\n    \"disciplina\": \"Legislação e Ética Profissional\",\n    \"tags\": [\n      \"NBC PG 01\"\n    ],\n    \"enunciado\": \"O Código de Ética Profissional do Contador prevê que, na aplicação das sanções éticas, pode ser considerada atenuante a\",\n    \"opcoes\": [\n      {\n        \"letra\": \"A\",\n        \"texto\": \"ausência de punição ética anterior.\"\n      },\n      {\n        \"letra\": \"B\",\n        \"texto\": \"prestação de serviços irrelevantes à contabilidade.\"\n      },\n      {\n        \"letra\": \"C\",\n        \"texto\": \"aplicação de desarrimo.\"\n      },\n      {\n        \"letra\": \"D\",\n        \"texto\": \"ação desenvolvida contra prerrogativas profissionais.\"\n      }\n    ],\n    \"gabarito\": \"\",\n    \"gabarito_texto\": \"\",\n    \"resolucao\": \"\",\n    \"autor_resolucao\": \"\",\n    \"obsoleta\": false,\n    \"anulada\": false,\n    \"lancamentos\": []\n  },\n  {\n    \"id\": 10,\n    \"ano\": 2024,\n    \"exame\": \"CFC 2024/2\",\n    \"banca\": \"FGV\",\n    \"disciplina\": \"Legislação e Ética Profissional\",\n    \"tags\": [\n      \"NBC PG 01\"\n    ],\n    \"enunciado\": \"De acordo com o Código de Ética Profissional, o contador pode praticar os seguintes atos, à exceção de um. Assinale-o.\",\n    \"opcoes\": [\n      {\n        \"letra\": \"A\",\n        \"texto\": \"Publicar trabalho, científico ou técnico, assinado e sob sua responsabilidade.\"\n      },\n      {\n        \"letra\": \"B\",\n        \"texto\": \"Transferir o contrato de serviços a seu cargo a outro profissional, com a anuência do cliente, sempre por escrito.\"\n      },\n      {\n        \"letra\": \"C\",\n        \"texto\": \"Transferir integralmente a execução dos serviços a seu cargo a outro profissional, mantendo como sua a responsabilidade técnica.\"\n      },\n      {\n        \"letra\": \"D\",\n        \"texto\": \"Indicar, em qualquer modalidade ou veículo de comunicação, títulos, especializações, serviços oferecidos, trabalhos realizados e a relação de clientes, esta quando autorizada por estes.\"\n      }\n    ],\n    \"gabarito\": \"\",\n    \"gabarito_texto\": \"\",\n    \"resolucao\": \"\",\n    \"autor_resolucao\": \"\",\n    \"obsoleta\": false,\n    \"anulada\": false,\n    \"lancamentos\": []\n  },",
